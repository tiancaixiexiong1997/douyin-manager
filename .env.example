# AI 服务配置（必填）
APP_TIMEZONE=Asia/Shanghai
AI_API_KEY=sk-your-api-key-here
AI_BASE_URL=https://api.openai-hub.com/v1
AI_MODEL=gemini-2.0-flash
AI_FAILOVER_ENABLED=false
AI_API_KEY_BACKUP=
AI_BASE_URL_BACKUP=
AI_MODEL_BACKUP=
# AI 调用总超时（秒）：多模态建议 120-240，文本建议 60-180
AI_MULTIMODAL_CALL_OVERALL_TIMEOUT_SECONDS=180
AI_TEXT_CALL_OVERALL_TIMEOUT_SECONDS=120
REDIS_URL=redis://redis:6379/0
JOB_QUEUE_NAME=default
# 入队前是否要求至少一个活跃 worker（建议生产保持 true）
REQUIRE_ACTIVE_WORKER_ON_ENQUEUE=true
# worker 心跳超时阈值（秒），超过则视为不活跃
WORKER_HEARTBEAT_TIMEOUT_SECONDS=120
# worker 启动时是否清理历史待执行任务（调试环境可设 true，避免重建后自动续跑）
WORKER_PURGE_PENDING_ON_STARTUP=false
# worker 启动时自动清理“重启遗留”失败任务（AbandonedJobError）
WORKER_PURGE_ABANDONED_FAILED_ON_STARTUP=true
# 删除代表作时是否自动重算博主综合报告（会额外调用一次 AI，默认关闭）
AUTO_REFRESH_REPORT_ON_REP_DELETE=false
# 队列任务自动重试策略
JOB_QUEUE_RETRY_MAX=1
JOB_QUEUE_RETRY_INTERVAL_SECONDS=30
# 判定“执行中任务卡住”的阈值（秒）
JOB_QUEUE_STUCK_JOB_TIMEOUT_SECONDS=1800
# 后端端口绑定（默认仅本机可访问，避免公网直接暴露 8000）
BACKEND_PORT_BIND=127.0.0.1:8000:8000

# 管理员登录配置（首次部署默认 admin123456，登录后建议立即修改）
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123456
# 建议使用至少 32 位随机字符串，例如：openssl rand -hex 32
AUTH_SECRET_KEY=replace-with-a-strong-random-secret
# 严格模式开启后，检测到弱密钥/弱口令将拒绝启动
SECURITY_STRICT_MODE=false
ENABLE_SECURITY_HEADERS=true
SECURITY_HSTS_SECONDS=31536000
ACCESS_TOKEN_EXPIRE_MINUTES=720
REFRESH_TOKEN_EXPIRE_DAYS=30
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
# 本地 HTTP 调试可临时改为 COOKIE_SECURE=false（生产务必保持 true）
# 若 COOKIE_SAMESITE=none，必须同时设置 COOKIE_SECURE=true
# COOKIE_DOMAIN=example.com
ACCESS_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token
AUTH_LOCK_MAX_ATTEMPTS=5
AUTH_LOCK_MINUTES=15
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
AUTH_RATE_LIMIT_MAX_ATTEMPTS=20
# 代理下载链路超时与分块配置
DOWNLOAD_PROXY_CONNECT_TIMEOUT_SECONDS=15
DOWNLOAD_PROXY_READ_TIMEOUT_SECONDS=120
DOWNLOAD_PROXY_FETCHER_TIMEOUT_SECONDS=10
DOWNLOAD_PROXY_CHUNK_SIZE_BYTES=524288
DOWNLOAD_PROXY_MAX_NETWORK_RETRIES=1
# API 响应压缩（建议开启，降低带宽开销）
ENABLE_GZIP=true
GZIP_MINIMUM_SIZE=1024
GZIP_COMPRESS_LEVEL=6
# 日志格式：false=文本，true=JSON
LOG_JSON=false
LOG_LEVEL=INFO
# 任务状态表保留天数（用于自动清理）
TASK_STATE_RETENTION_DAYS=14
# 后台任务状态清理的最小间隔（分钟）
TASK_STATE_CLEANUP_INTERVAL_MINUTES=60
# 服务启动时是否强制执行一次过期清理
TASK_STATE_CLEANUP_ON_STARTUP=true
# 启动时自动执行 Alembic 迁移
RUN_ALEMBIC_ON_STARTUP=true
# 数据库备份保留天数（供 scripts/backup_db.sh 使用）
BACKUP_RETENTION_DAYS=14

# 数据库（默认 SQLite，无需修改）
# DATABASE_URL=sqlite+aiosqlite:///./data/douyincehua.db
